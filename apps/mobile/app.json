{
  "expo": {
    "name": "KnotWise",
    "slug": "knotwise",
    "scheme": "knotwise",
    "version": "0.3.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#f7f4ef"
    },
    "ios": {
      "bundleIdentifier": "in.knotwise.app",
      "supportsTablet": false
    },
    "android": {
      "package": "in.knotwise.app",
      "adaptiveIcon": {
        "backgroundColor": "#f7f4ef"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#c41e1e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "knotwise-mobile"
      }
    }
  }
}
