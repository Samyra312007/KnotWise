generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  stripeCustomerId String?
  createdAt        DateTime @default(now())

  members           Membership[]
  customers         Customer[]
  poolProfiles      PoolProfile[]
  subscriptions     Subscription[]
  threads           Thread[]
  verificationCases VerificationCase[]
  assets            Asset[]
  matchingConfig    OrgMatchingConfig?
  modelVersions     ModelVersion[]
  auditEvents       AuditEvent[]
  matchExperiments  MatchExperiment[]
  analyticsEvents   AnalyticsEvent[]
  crmLeads          CrmLead[]
}

model Membership {
  id           String @id @default(cuid())
  orgId        String
  matchmakerId String
  role         String

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  matchmaker Matchmaker  @relation(fields: [matchmakerId], references: [id], onDelete: Cascade)

  @@unique([orgId, matchmakerId])
  @@index([matchmakerId])
}

model Matchmaker {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  fullName     String
  createdAt    DateTime @default(now())

  memberships   Membership[]
  assignments   CustomerAssignment[]
  collaborators CustomerCollaborator[]
  notes         Note[]
  emails        EmailLog[]
  notifications Notification[]
  handoffsFrom  Handoff[]          @relation("HandoffFrom")
  handoffsTo    Handoff[]          @relation("HandoffTo")
  mobileTokens MobileAuthToken[]
  crmLeadsAssigned CrmLead[]        @relation("LeadAssignee")
}

model Customer {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  firstName     String
  lastName      String
  gender        String
  dateOfBirth   DateTime
  city          String
  country       String
  maritalStatus String

  stage      String    @default("Onboarding")
  biodata    String
  photoUrl   String?
  verifiedAt DateTime?
  verificationTier String    @default("unverified")
  phoneVerifiedAt  DateTime?
  photoVerifiedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments           CustomerAssignment[]
  collaborators         CustomerCollaborator[]
  notes                 Note[]
  suggestions           MatchSuggestion[]
  clientAccount         ClientAccount?
  clientBilling         ClientBilling?
  handoffs              Handoff[]
  thread                Thread?
  profileChangeRequests ProfileChangeRequest[]
  profileRevisions      ProfileRevision[]
  poolMirror            PoolProfile?
  mutualMatchesAsA      MutualMatch[]          @relation("MutualClientA")
  mutualMatchesAsB      MutualMatch[]          @relation("MutualClientB")
  schedulesProposed     ScheduledEvent[]       @relation("ScheduleProposer")
  blocksCreated         Block[]                @relation("Blocker")
  blocksReceived        Block[]                @relation("Blocked")
  c2cMessagesSent       C2cMessage[]
  reportsFiled          Report[]               @relation("ReportReporter")
  discoveryInterests    DiscoveryInterest[]
  familyDelegates       FamilyDelegate[]
  clientIntroRequests   ClientIntroRequest[]
  billingCheckoutSessions BillingCheckoutSession[]
  billingInvoices       ClientBillingInvoice[]
  preferenceSignals     PreferenceSignal[]
  analyticsEvents     AnalyticsEvent[]
  crmLead               CrmLead?

  @@index([orgId])
  @@index([stage])
  @@index([gender])
}

model CustomerAssignment {
  id           String @id @default(cuid())
  customerId   String
  matchmakerId String
  role         String

  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  matchmaker Matchmaker @relation(fields: [matchmakerId], references: [id], onDelete: Cascade)

  @@unique([customerId, matchmakerId])
}

model CustomerCollaborator {
  id           String @id @default(cuid())
  customerId   String
  matchmakerId String
  access       String

  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  matchmaker Matchmaker @relation(fields: [matchmakerId], references: [id], onDelete: Cascade)

  @@unique([customerId, matchmakerId])
}

model PoolProfile {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String
  gender      String
  dateOfBirth DateTime
  city        String
  country     String
  biodata     String
  photoUrl    String?
  verifiedAt  DateTime?

  linkedCustomerId String?  @unique
  linkedCustomer   Customer? @relation(fields: [linkedCustomerId], references: [id], onDelete: SetNull)

  suggestions MatchSuggestion[]
  discoveryInterests DiscoveryInterest[]

  searchText String?

  @@index([orgId])
  @@index([gender])
  @@index([city])
}

model MatchSuggestion {
  id            String @id @default(cuid())
  customerId    String
  poolProfileId String

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  poolProfile PoolProfile @relation(fields: [poolProfileId], references: [id], onDelete: Cascade)

  score            Int
  bucket           String
  explanation      String
  breakdown        String
  status           String    @default("shortlisted")
  shortlistedAt    DateTime?
  shortlistedBy    String?
  feedbackReason   String?
  feedbackAt       DateTime?
  viewedAt         DateTime?
  introPairId      String?
  modelAdjusted    Boolean   @default(false)

  createdAt DateTime @default(now())

  emails      EmailLog[]
  mutualMatch MutualMatch?

  @@unique([customerId, poolProfileId])
  @@index([customerId, status])
  @@index([introPairId])
}

model MutualMatch {
  id                String    @id @default(cuid())
  matchSuggestionId String    @unique
  introPairId       String?
  clientAId         String
  clientBId         String
  status            String    @default("active")
  contactSharedAt   DateTime?
  createdAt         DateTime  @default(now())

  matchSuggestion MatchSuggestion @relation(fields: [matchSuggestionId], references: [id], onDelete: Cascade)
  clientA         Customer        @relation("MutualClientA", fields: [clientAId], references: [id], onDelete: Cascade)
  clientB         Customer        @relation("MutualClientB", fields: [clientBId], references: [id], onDelete: Cascade)
  conversation    Conversation?
  scheduledEvents ScheduledEvent[]

  @@index([clientAId])
  @@index([clientBId])
  @@index([introPairId])
}

model ScheduledEvent {
  id             String    @id @default(cuid())
  mutualMatchId  String
  proposedById   String
  startsAt       DateTime
  endsAt         DateTime?
  mode           String    @default("video")
  title          String?
  location       String?
  status         String    @default("proposed")
  videoLink      String?
  videoRoomId    String?
  videoProvider  String?
  reminderSentAt DateTime?
  respondedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  mutualMatch MutualMatch @relation(fields: [mutualMatchId], references: [id], onDelete: Cascade)
  proposedBy  Customer    @relation("ScheduleProposer", fields: [proposedById], references: [id], onDelete: Cascade)

  @@index([mutualMatchId, status])
  @@index([startsAt, status])
}

model Note {
  id           String @id @default(cuid())
  customerId   String
  matchmakerId String
  body         String
  mentions     String @default("[]")

  createdAt DateTime @default(now())

  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  matchmaker Matchmaker @relation(fields: [matchmakerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

model EmailLog {
  id                String @id @default(cuid())
  matchSuggestionId String
  matchmakerId      String

  subject        String
  body           String
  sentAt         DateTime @default(now())
  deliveryStatus String   @default("queued")
  providerId     String?
  deliveredAt    DateTime?
  errorMessage   String?
  recipientEmail String?

  matchSuggestion MatchSuggestion @relation(fields: [matchSuggestionId], references: [id], onDelete: Cascade)
  matchmaker      Matchmaker      @relation(fields: [matchmakerId], references: [id], onDelete: Cascade)

  @@index([matchmakerId, sentAt])
}

model ClientAccount {
  id              String    @id @default(cuid())
  customerId      String    @unique
  email           String    @unique
  phone           String?
  passwordHash    String?
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  notifyEmail     Boolean   @default(true)
  onboardingStep  Int       @default(0)
  onboardingCompletedAt DateTime?
  delegateApproverOptIn Boolean @default(false)

  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  magicLinks MagicLinkToken[]
  verificationAttempts VerificationAttempt[]
  deviceTokens DeviceToken[]
  notificationPreference NotificationPreference?
  mobileTokens ClientMobileAuthToken[]
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  clientId  String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?

  client ClientAccount @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

model Subscription {
  id                   String   @id @default(cuid())
  orgId                String   @unique
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String
  currentPeriodEnd     DateTime
  seatCount            Int      @default(3)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model ClientBilling {
  id                     String    @id @default(cuid())
  customerId             String    @unique
  provider               String    @default("none")
  stripeCustomerId       String?
  razorpayCustomerId     String?
  razorpaySubscriptionId String?   @unique
  plan                   String    @default("included")
  status                 String    @default("active")
  currentPeriodEnd       DateTime?
  gstin                  String?
  introRequestsPeriod    String?
  introRequestsUsed      Int       @default(0)
  pastDueSince           DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Handoff {
  id               String    @id @default(cuid())
  customerId       String
  fromMatchmakerId String
  toMatchmakerId   String
  note             String
  status           String    @default("pending")
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?

  customer       Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fromMatchmaker Matchmaker @relation("HandoffFrom", fields: [fromMatchmakerId], references: [id])
  toMatchmaker   Matchmaker @relation("HandoffTo", fields: [toMatchmakerId], references: [id])

  @@index([toMatchmakerId, status])
}

model Thread {
  id         String @id @default(cuid())
  customerId String @unique
  orgId      String

  customer     Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  org          Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages     ThreadMessage[]
  participants ThreadParticipant[]
}

model ThreadMessage {
  id         String   @id @default(cuid())
  threadId   String
  authorId   String
  authorType String
  body       String
  mentions   String   @default("[]")
  createdAt  DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model ThreadParticipant {
  id         String    @id @default(cuid())
  threadId   String
  userId     String
  userType   String
  lastReadAt DateTime?

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId, userType])
}

model Notification {
  id           String    @id @default(cuid())
  matchmakerId String
  type         String
  payload      String
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  matchmaker Matchmaker @relation(fields: [matchmakerId], references: [id], onDelete: Cascade)

  @@index([matchmakerId, readAt])
}

model VerificationCase {
  id          String    @id @default(cuid())
  orgId       String
  entityType  String
  entityId    String
  status      String    @default("pending")
  priority    Int       @default(0)
  checklist   String    @default("{}")
  reviewerId  String?
  notes       String?
  submittedAt DateTime  @default(now())
  resolvedAt  DateTime?

  org       Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  documents VerificationDocument[]

  @@index([orgId, status])
  @@index([entityType, entityId])
}

model VerificationDocument {
  id         String   @id @default(cuid())
  caseId     String
  kind       String
  fileUrl    String
  uploadedBy String
  createdAt  DateTime @default(now())

  verificationCase VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model Asset {
  id         String   @id @default(cuid())
  orgId      String
  entityType String
  entityId   String
  kind       String   @default("photo")
  url        String
  key        String
  mimeType   String
  sizeBytes  Int
  uploadedBy String
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, kind])
}

model ProfileRevision {
  id         String    @id @default(cuid())
  customerId String
  fieldPath  String
  oldValue   String
  newValue   String
  status     String    @default("pending")
  reviewedBy String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, status])
  @@index([status, createdAt])
}

model OrgMatchingConfig {
  id             String   @id @default(cuid())
  orgId          String   @unique
  weightsJson    String
  mlEnabled      Boolean  @default(false)
  blockSameGotra Boolean  @default(true)
  discoveryEnabled      Boolean @default(true)
  discoveryDailyLimit   Int     @default(20)
  kundliEnabled         Boolean @default(false)
  weightPreset          String  @default("v1")
  experimentVariant     String  @default("control")
  updatedAt      DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model DiscoveryInterest {
  id            String   @id @default(cuid())
  customerId    String
  poolProfileId String
  status        String   @default("pending")
  note          String?
  createdAt     DateTime @default(now())

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  poolProfile PoolProfile @relation(fields: [poolProfileId], references: [id], onDelete: Cascade)

  @@unique([customerId, poolProfileId])
  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

model ModelVersion {
  id        String   @id @default(cuid())
  orgId     String
  version   Int
  metrics   String
  artifactKey String?
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, version])
}

model AuditEvent {
  id         String   @id @default(cuid())
  orgId      String
  actorId    String
  actorType  String
  action     String
  entityType String
  entityId   String
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
}

model ProfileChangeRequest {
  id         String   @id @default(cuid())
  customerId String
  body       String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  resolvedAt DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Conversation {
  id            String   @id @default(cuid())
  mutualMatchId String   @unique
  createdAt     DateTime @default(now())

  mutualMatch MutualMatch  @relation(fields: [mutualMatchId], references: [id], onDelete: Cascade)
  messages    C2cMessage[]
}

model C2cMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime  @default(now())
  readAt         DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Customer     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker Customer @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked Customer @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model VerificationAttempt {
  id         String    @id @default(cuid())
  clientId   String
  channel    String
  target     String
  codeHash   String
  expiresAt  DateTime
  verifiedAt DateTime?
  failCount  Int       @default(0)
  createdAt  DateTime  @default(now())

  client ClientAccount @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([target, channel])
  @@index([clientId, createdAt])
}

model Report {
  id         String    @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  status     String    @default("open")
  reviewerId String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  reporter Customer @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reporterId])
}

model MobileAuthToken {
  id           String    @id @default(cuid())
  matchmakerId String
  tokenHash    String    @unique
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  matchmaker Matchmaker @relation(fields: [matchmakerId], references: [id], onDelete: Cascade)
}

model DeviceToken {
  id        String   @id @default(cuid())
  clientId  String
  platform  String
  token     String   @unique
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  client ClientAccount @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model NotificationPreference {
  id           String  @id @default(cuid())
  clientId     String  @unique
  introPush    Boolean @default(true)
  messagePush  Boolean @default(true)
  reminderPush Boolean @default(true)

  client ClientAccount @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientMobileAuthToken {
  id        String    @id @default(cuid())
  clientId  String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  client ClientAccount @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model FamilyDelegate {
  id              String    @id @default(cuid())
  customerId      String
  email           String
  role            String
  status          String    @default("invited")
  invitedAt       DateTime  @default(now())
  acceptedAt      DateTime?
  revokedAt       DateTime?
  inviteTokenHash String?

  customer     Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  magicLinks   DelegateMagicLinkToken[]
  mobileTokens DelegateAuthToken[]

  @@unique([customerId, email])
  @@index([email, status])
}

model DelegateMagicLinkToken {
  id         String    @id @default(cuid())
  delegateId String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  delegate FamilyDelegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)

  @@index([delegateId])
}

model DelegateAuthToken {
  id         String    @id @default(cuid())
  delegateId String
  tokenHash  String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  delegate FamilyDelegate @relation(fields: [delegateId], references: [id], onDelete: Cascade)

  @@index([delegateId])
}

model BillingCheckoutSession {
  id              String    @id @default(cuid())
  customerId      String
  idempotencyKey  String    @unique
  plan            String
  amountInr       Int
  razorpayOrderId String?   @unique
  razorpaySubId   String?
  status          String    @default("pending")
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model BillingWebhookEvent {
  id          String   @id @default(cuid())
  provider    String
  eventId     String
  eventType   String
  payload     String?
  processedAt DateTime @default(now())

  @@unique([provider, eventId])
}

model ClientBillingInvoice {
  id         String   @id @default(cuid())
  customerId String
  provider   String
  externalId String
  amountInr  Int
  gstInr     Int      @default(0)
  status     String
  invoiceUrl String?
  issuedAt   DateTime

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([provider, externalId])
  @@index([customerId])
}

model ClientIntroRequest {
  id         String   @id @default(cuid())
  customerId String
  note       String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

model PreferenceSignal {
  id            String   @id @default(cuid())
  customerId    String
  poolProfileId String?
  suggestionId  String?
  signalType    String
  dwellMs       Int?
  metadata      String?
  createdAt     DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([poolProfileId])
}

model AstroProfile {
  id         String    @id @default(cuid())
  entityType String
  entityId   String
  birthTime  String?
  birthPlace String?
  consentAt  DateTime?
  kundliJson String?
  fetchedAt  DateTime?

  @@unique([entityType, entityId])
}

model MatchExperiment {
  id         String    @id @default(cuid())
  orgId      String
  key        String
  variant    String
  status     String    @default("active")
  configJson String    @default("{}")
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  orgId      String
  eventName  String
  customerId String?
  entityType String?
  entityId   String?
  properties String   @default("{}")
  createdAt  DateTime @default(now())

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([orgId, eventName, createdAt])
  @@index([orgId, createdAt])
}

model CrmLead {
  id             String    @id @default(cuid())
  orgId          String
  customerId     String    @unique
  stage          String    @default("lead")
  priority       String    @default("normal")
  source         String    @default("signup")
  notes          String?
  lastContactAt  DateTime?
  nextFollowUpAt DateTime?
  assigneeId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignee Matchmaker?  @relation("LeadAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([orgId, stage])
  @@index([orgId, nextFollowUpAt])
}
